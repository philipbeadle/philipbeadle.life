---
const rows = [
  { year: '2023 — now', role: 'Founder · AgenticScale.ai', detail: 'AgenticGrid simulation platform · RACE for 2030 project at Monash · Australian energy regulators and network operators.' },
  { year: '2022', role: 'Founding contributor · IOEN.tech', detail: 'Internet of Energy Network. Connection and value exchange between any energy device, user, or market.' },
  { year: '2018 — 2025', role: 'Core team · Holochain / Holo', detail: 'Seven years building RAD tools and hApps for the agent-centric protocol stack. holo.host distributed hosting ecosystem.' },
  { year: '2021', role: 'Xienta', detail: 'Generative AI tooling — freedom to create, invent and ship products faster.' },
  { year: '2017 — 2018', role: 'Elabor8', detail: 'Helping organisations challenge the impossible at scale.' },
  { year: '2014 — 2017', role: 'Odecee (Cognizant Digital Business)', detail: 'Drove the go-to-market technology vision for the Automation Practice, ANZ. Built the test-automation strategy that scaled across one of Australia\'s big-four banks.' },
  { year: '2009 — 2014', role: 'Planit Software Testing', detail: 'Built the automation capability so the firm didn\'t have to rely solely on manual testing.' },
  { year: '2005 — 2009', role: 'Principal Consultant · Readify', detail: 'Continuous-delivery test framework for a Microsoft × VISA joint project — zero bug bounce across two years, ten engineers.' },
  { year: '2002 — onwards', role: 'Co-creator · DNN', detail: 'One of the original .NET open-source projects. Wrote "Silverlight for Dummies" (Wiley, 2010). Microsoft MVP × 5 years.' },
  { year: '2000 — 2004', role: 'Founder · Nexxus Systems International', detail: 'Web and ISP solutions. Sold to Byte in 2004.' },
  { year: '1993 — 1997', role: 'Bachelor of Engineering (Honours), Chemical Engineering · Curtin University', detail: 'Real engineering credential. Why I think in systems and feedback loops, not just code.' },
];
---
<section id="timeline" class="relative border-t border-bone-400/10 py-28 sm:py-36">
  <div class="mx-auto max-w-wide px-6 sm:px-10">
    <div class="flex items-start justify-between gap-12">
      <div class="max-w-narrow">
        <p class="eyebrow">The Timeline · 04</p>
        <h2 class="display-h2 mt-6">
          A long arc, on purpose.
        </h2>
        <p class="body-lg mt-8">
          Thirty years of shipping software, fifteen of it inside open-source projects, the last seven inside agent-centric protocols. Every chapter compounds into the next.
        </p>
      </div>
      <div class="chapter-marker hidden lg:block">04</div>
    </div>

    <div class="mt-16 divide-y divide-bone-400/10 border-y border-bone-400/10">
      {rows.map((row) => (
        <div class="grid gap-2 py-6 lg:grid-cols-[12rem_1fr] lg:items-baseline lg:gap-12">
          <p class="font-mono text-[11px] uppercase tracking-widest text-bone-400">{row.year}</p>
          <div>
            <p class="display-h3 text-lg sm:text-xl">{row.role}</p>
            <p class="body mt-2 text-sm">{row.detail}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-bone-400/10 bg-bone-400/10 sm:grid-cols-3">
      <div class="bg-ink-900 p-8">
        <p class="eyebrow">Recognition</p>
        <p class="display-h3 mt-4 text-lg">Microsoft MVP · 5 years</p>
        <p class="body mt-3 text-sm">Plus Visual Studio 2005 ACE Contributor.</p>
      </div>
      <div class="bg-ink-900 p-8">
        <p class="eyebrow">Published</p>
        <p class="display-h3 mt-4 text-lg">Silverlight for Dummies</p>
        <p class="body mt-3 text-sm">Wiley · May 2010.</p>
      </div>
      <div class="bg-ink-900 p-8">
        <p class="eyebrow">Awards</p>
        <p class="display-h3 mt-4 text-lg">ANZ Consumer Digital Excellence</p>
        <p class="body mt-3 text-sm">Readify Summit Club · Victorian Govt ICT Showcase.</p>
      </div>
    </div>
  </div>
</section>
