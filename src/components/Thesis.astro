---
const frames = [
  {
    audience: 'For regulators',
    headline: 'A platform you can actually cite.',
    body: 'Every scenario is signed, content-addressed, reproducible. The Australian Energy Regulator can re-run a DNSP\'s RIT-D submission against current AER inputs in minutes, not months. Independent review becomes structural, not a separate verification pass.',
  },
  {
    audience: 'For network operators',
    headline: 'A simulation environment that compounds.',
    body: 'Every cleaned topology, every Optuna-tuned calibration, every 2030 DER scenario contributes to a corpus that every other operator benefits from. Stop rebuilding the same zone substation. Start sharing the work that makes the next decision faster.',
  },
  {
    audience: 'For the commons',
    headline: 'Cognitive capital, owned in public.',
    body: 'Sovereign agent-centric federation on Holochain. Public hosting on Holo. Contribution attribution and royalty distribution via Unyt. The network knowledge under management belongs to its contributors — not to a SaaS vendor.',
  },
];
---
<section id="thesis" class="relative border-t border-bone-400/10 py-28 sm:py-36">
  <div class="mx-auto max-w-wide px-6 sm:px-10">
    <div class="flex items-start justify-between gap-12">
      <div class="max-w-narrow">
        <p class="eyebrow">The Thesis · 02</p>
        <h2 class="display-h2 mt-6">
          Three ways to read the same system.
        </h2>
        <p class="body-lg mt-8">
          AgenticGrid serves a different but equally critical function depending on who's looking at it. The thesis is the same in every case: AI-powered simulations that let every stakeholder in the energy transformation work together.
        </p>
      </div>
      <div class="chapter-marker hidden lg:block">02</div>
    </div>

    <div class="mt-20 grid gap-px overflow-hidden rounded-2xl border border-bone-400/10 bg-bone-400/10 lg:grid-cols-3">
      {frames.map((frame) => (
        <article class="flex flex-col bg-ink-900 p-10">
          <p class="eyebrow">{frame.audience}</p>
          <h3 class="display-h3 mt-6">{frame.headline}</h3>
          <p class="body mt-6">{frame.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
