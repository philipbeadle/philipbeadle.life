---
const channels = [
  {
    label: 'Email',
    value: 'philip.beadle@live.com.au',
    href: 'mailto:philip.beadle@live.com.au',
    external: false,
  },
  {
    label: 'SMS — don\'t call',
    value: '+61 417 301 024',
    href: 'sms:+61417301024',
    external: false,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/philipbeadle',
    href: 'https://www.linkedin.com/in/philipbeadle',
    external: true,
  },
];
---
<section id="contact" class="relative border-t border-bone-400/10 py-28 sm:py-36">
  <div class="absolute inset-x-0 top-1/2 -z-10 mx-auto h-[28rem] w-[28rem] -translate-y-1/2 rounded-full bg-mint/[0.06] blur-[120px]"></div>
  <div class="mx-auto max-w-narrow px-6 sm:px-10" data-reveal>
    <div class="text-center">
      <p class="eyebrow">Let's talk · 05</p>
      <h2 class="display-h2 mt-6">
        If you're working on the energy transformation,
        <span class="text-mint">we should be talking.</span>
      </h2>
      <p class="body-lg mx-auto mt-8 max-w-prose">
        Regulators, network operators, researchers, founders, Holochain people — I want to hear from you. Especially if you've been waiting for the energy use case for as long as we have.
      </p>
    </div>

    <div class="mt-14 overflow-hidden rounded-2xl border border-bone-400/10 bg-ink-800/40 divide-y divide-bone-400/10">
      {channels.map((c) => (
        <a
          href={c.href}
          target={c.external ? '_blank' : undefined}
          rel={c.external ? 'noopener' : undefined}
          class="group flex flex-col gap-1 px-6 py-6 transition-colors hover:bg-ink-800 sm:flex-row sm:items-center sm:justify-between sm:px-8"
        >
          <span class="eyebrow">{c.label}</span>
          <span class="flex items-center gap-3 font-display text-lg text-bone-50 transition-colors group-hover:text-mint sm:text-xl">
            {c.value}
            <span aria-hidden class="text-bone-400 transition-all group-hover:translate-x-0.5 group-hover:text-mint">↗</span>
          </span>
        </a>
      ))}
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
      <a href="mailto:philip.beadle@live.com.au?subject=AgenticGrid%20Phase%202" class="pill">Talk about Phase 2</a>
      <a href="#top" class="pill-outline">Back to top</a>
    </div>
  </div>
</section>
