---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Philip Beadle — Building the operating system for the energy transformation',
  description = 'Founder of AgenticScale.ai and its AgenticGrid.ai platform. Co-founder of AgenticGrid Foundation. Five years on the Holochain core team. AI-powered simulations that let every stakeholder in the energy transformation work together.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://philipbeadle.life/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/avatar.png" />
    <link rel="apple-touch-icon" href="/avatar.png" />
  </head>
  <body class="min-h-screen bg-ink-900 text-bone-100">
    <slot />
    <script is:inline>
      (() => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.12 }
        );

        const reveal = (el) => {
          if (reduce) {
            el.classList.add('in');
            return;
          }
          io.observe(el);
        };

        // Single elements
        document.querySelectorAll('[data-reveal]').forEach(reveal);

        // Staggered groups — direct children animate in sequence
        document.querySelectorAll('[data-reveal-stagger]').forEach((group) => {
          Array.from(group.children).forEach((child, i) => {
            child.classList.add('reveal');
            child.style.transitionDelay = Math.min(i * 90, 540) + 'ms';
            reveal(child);
          });
        });
      })();
    </script>
  </body>
</html>
